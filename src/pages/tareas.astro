---
import Layout from '../layouts/Layout.astro';
import TaskView from '../components/features/TaskView';
import TaskInput from '../components/features/TaskInput';
---

<Layout title="La Libreta - Tareas">
  <div class="max-w-3xl mx-auto space-y-8 animate-in fade-in zoom-in duration-500">
    <div class="mb-2 px-2">
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Tareas</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Gestiona tus pendientes y tareas diarias.</p>
    </div>
    <section>
      <TaskInput client:load />
    </section>

    <TaskView client:load />
  </div>
</Layout>
