---
import Layout from '../layouts/Layout.astro';
import ProjectManager from '../components/features/ProjectManager';
---

<Layout title="La Libreta - Proyectos">
  <div class="space-y-6 max-w-5xl mx-auto h-full flex flex-col">
    
    <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
      <div>
        <h1 class="text-3xl font-bold bg-clip-text text-transparent bg-linear-to-r from-amber-400 to-amber-600 dark:from-amber-300 dark:to-amber-500">
          Proyectos Activos
        </h1>
        <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">Gestiona presupuestos y operaciones de tus clientes.</p>
      </div>
    </header>

    <section class="grow pb-24">
      <!-- Interactive React Project Grid & Creation Modal -->
      <ProjectManager client:load />
    </section>

  </div>
</Layout>
