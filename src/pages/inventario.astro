---
import Layout from '../layouts/Layout.astro';
import InventoryManager from '../components/features/InventoryManager';
---

<Layout title="La Libreta - Inventario">
  <div class="max-w-4xl mx-auto space-y-8 animate-in fade-in zoom-in duration-500">
    <div class="mb-2 px-2">
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Inventario</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Gestiona tu catálogo y registra compras de productos e insumos.</p>
    </div>
    <InventoryManager client:load />
  </div>
</Layout>
