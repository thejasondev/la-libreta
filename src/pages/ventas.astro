---
import Layout from '../layouts/Layout.astro';
import SalesPanel from '../components/features/SalesPanel';
import ModeToggle from '../components/ui/ModeToggle';
---

<Layout title="La Libreta - Ventas">
  <div class="max-w-4xl mx-auto space-y-8 animate-in fade-in zoom-in duration-500">
    <div class="mb-2 px-2 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Ventas</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Registra las ventas de tu negocio. Selecciona productos o servicios del catálogo.</p>
      </div>
      <ModeToggle client:load />
    </div>

    <!-- Business mode: SalesPanel POS -->
    <div>
      <SalesPanel client:load />
    </div>
  </div>
</Layout>
