---
import Layout from '../layouts/Layout.astro';
import ExpenseView from '../components/features/ExpenseView';
import ExpenseInput from '../components/features/ExpenseInput';
---

<Layout title="La Libreta - Gastos">
  <div class="max-w-4xl mx-auto space-y-8 animate-in fade-in zoom-in duration-500">
    <div class="mb-2 px-2">
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Gastos e Ingresos</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Registra tus movimientos financieros y controla tu presupuesto.</p>
    </div>
    <section>
      <ExpenseInput client:load />
    </section>
    <ExpenseView client:load />
  </div>
</Layout>
